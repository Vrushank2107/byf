# Backend API URL (set to production API URL when deploying)
VITE_API_URL=http://localhost:3001

# Public site URL for sitemap, canonical links, Open Graph, and robots.txt
# Set to your production domain (no trailing slash)
VITE_SITE_URL=https://barodayouthfederation.org

# Do NOT set NODE_ENV here or in Vercel project env vars. Vite/TanStack Start bake JSX
# transforms at build time; NODE_ENV=development causes SSR 500s (jsxDEV is not a function).
