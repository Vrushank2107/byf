# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Server
PORT=3001
NODE_ENV=development

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Optional: Redis for distributed rate limiting (falls back to in-memory if unset)
REDIS_URL=

# Cookie settings for cross-origin admin auth (use None when frontend/API are on different domains)
COOKIE_SAME_SITE=Lax

# Admin authentication (required in production)
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_PASSWORD=your-secure-admin-password

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (donations)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
