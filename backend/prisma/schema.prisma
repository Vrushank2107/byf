generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id         String          @id @default(uuid()) @db.Uuid
  slug       String          @unique
  title      String
  category   ProjectCategory
  short      String
  image      String
  stats      Json            @default("[]")
  progress   Int             @default(0) @db.SmallInt
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  fullStory  String?         @map("full_story")
  showInHero Boolean         @default(false) @map("show_in_hero")
  images     Json            @default("[]")

  @@index([category])
  @@index([showInHero])
  @@map("projects")
}

model Gallery {
  id        String   @id @default(uuid()) @db.Uuid
  src       String
  tag       String
  alt       String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tag])
  @@map("gallery")
}

model Event {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  date        DateTime @db.Date
  location    String
  description String
  image       String
  upcoming    Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([date])
  @@index([upcoming])
  @@map("events")
}

model Blog {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  title     String
  excerpt   String
  category  String
  date      DateTime @db.Date
  image     String
  read      String
  content   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("blog")
}

model Volunteer {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String
  phone        String
  address      String
  skills       String
  availability String
  resumeName   String?  @map("resume_name")
  resumeUrl    String?  @map("resume_url")
  reviewed     Boolean  @default(false)
  submittedAt  DateTime @default(now()) @map("submitted_at") @db.Timestamptz(6)

  @@index([reviewed])
  @@map("volunteers")
}

model Message {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  email       String
  phone       String
  subject     String
  message     String
  read        Boolean  @default(false)
  submittedAt DateTime @default(now()) @map("submitted_at") @db.Timestamptz(6)

  @@index([read])
  @@map("messages")
}

model SiteSettings {
  id                  String   @id @default(uuid()) @db.Uuid
  email               String
  phone               String
  whatsapp            String
  whatsappName        String   @map("whatsapp_name")
  address             String
  instagram           String
  facebook            String
  twitter             String
  youtube             String
  founderPortfolioUrl String   @default("") @map("founder_portfolio_url")
  updatedAt           DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  homeHeroImage       String   @default("") @map("home_hero_image")
  aboutHeroImage      String   @default("") @map("about_hero_image")
  projectsHeroImage   String   @default("") @map("projects_hero_image")
  eventsHeroImage     String   @default("") @map("events_hero_image")
  galleryHeroImage    String   @default("") @map("gallery_hero_image")
  blogHeroImage       String   @default("") @map("blog_hero_image")
  contactHeroImage    String   @default("") @map("contact_hero_image")
  volunteerHeroImage  String   @default("") @map("volunteer_hero_image")
  donateHeroImage     String   @default("") @map("donate_hero_image")
  donationFunds       Json     @default("[]")

  @@map("site_settings")
}

model Activity {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  tag       String
  date      String
  image     String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("activities")
}

model Testimonial {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  role      String
  quote     String
  image     String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("testimonials")
}

model ImpactStat {
  id        String   @id @default(uuid()) @db.Uuid
  label     String
  value     String
  suffix    String?
  color     String   @default("primary")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("impact_stats")
}

model Leader {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  role      String
  bio       String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("leaders")
}

model Partner {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("partners")
}

model Donation {
  id                String         @id @default(uuid()) @db.Uuid
  name              String
  email             String
  phone             String
  address           String
  pan               String?
  amount            Int
  fund              String
  status            DonationStatus @default(Pending)
  razorpayOrderId   String?        @map("razorpay_order_id")
  razorpayPaymentId String?        @map("razorpay_payment_id")
  razorpaySignature String?        @map("razorpay_signature")
  receiptNumber     String?        @unique @map("receipt_number")
  receiptGenerated  Boolean        @default(false) @map("receipt_generated")
  isAnonymous       Boolean        @default(false) @map("is_anonymous")
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([status])
  @@index([fund])
  @@map("donations")
}

enum ProjectCategory {
  Education
  WomenEmpowerment
  CommunityWelfare
  DisasterRelief
  CulturalActivities
}

enum DonationStatus {
  Pending
  Completed
  Failed
  Refunded
}
